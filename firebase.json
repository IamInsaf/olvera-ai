{
  "hosting": {
    "public": "public",
    "site": "proway",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/vresults",
        "destination": "/smart-voice/vresults.html"
      },
      {
        "source": "/premiumresults",
        "destination": "/premiumv1/premiumresults.html"
      },
      {
        "source": "/privacy-policy",
        "destination": "/policies/privacy.html"
      },
      {
        "source": "/terms-and-conditions",
        "destination": "/policies/terms-and-conditions.html"
      },
      {
        "source": "/searchJob",
        "function": "searchJob"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "runtime": "nodejs18",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true
    }
  }
}

